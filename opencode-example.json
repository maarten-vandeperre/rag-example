{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "redhat-openshift-vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen Local",
      "options": {
        "baseURL": "https://<vLLM compliant model as a service domain>/v1",
        "apiKey": "<API_KEY>"
      },
      "models": {
        "qwen3-14b": {
          "name": "Qwen 3 14B",
          "options": {
            "max_tokens": 8192,
            "temperature": 0.1
          }
        },
        "deepseek-r1-distill-qwen-14b": {
          "name": "DeepSeek R1 Distill Qwen 14B",
          "options": {
            "max_tokens": 8192,
            "temperature": 0.1
          }
        },
        "granite-3-2-8b-instruct": {
          "name": "Granite 3 2 8B Instruct",
          "options": {
            "max_tokens": 8192,
            "temperature": 0.1
          }
        }
      }
    }
  },
  "model": "redhat-openshift-vllm/deepseek-r1-distill-qwen-14b"
}
COMPOSE_PROJECT_NAME=rag-dev

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_app_dev
DB_USER=rag_dev_user
DB_PASSWORD=rag_dev_password
DB_URL=jdbc:postgresql://localhost:5432/rag_app_dev

WEAVIATE_PORT=8080
WEAVIATE_URL=http://localhost:8080
WEAVIATE_QUERY_LIMIT=25
WEAVIATE_ENABLED_MODULES=

KEYCLOAK_PORT=8180
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=rag-app-dev
KEYCLOAK_CLIENT_ID=rag-app-frontend
KEYCLOAK_CLIENT_SECRET=backend-dev-secret
KEYCLOAK_BACKEND_CLIENT_ID=rag-app-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-dev-secret
KEYCLOAK_FRONTEND_CLIENT_ID=rag-app-frontend
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_URL=http://localhost:7474
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev-password
NEO4J_AUTH=neo4j/dev-password
NEO4J_DATABASE=neo4j
NEO4J_HEAP_INITIAL=512M
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE_SIZE=256M

OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
LLM_MODEL=tinyllama
OLLAMA_PULL_MODELS=tinyllama
START_LLM=true

BACKEND_PORT=8081
FRONTEND_PORT=3000
API_BASE_URL=http://localhost:8081/api

ENVIRONMENT=development
DEBUG_MODE=true
LOG_LEVEL=DEBUG
